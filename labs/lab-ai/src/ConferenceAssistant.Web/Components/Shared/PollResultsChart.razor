@using ConferenceAssistant.Core.Models

<div class="results-chart">
    <h3>@Poll.Question</h3>
    <div class="chart-bars">
        @if (Results is not null)
        {
            var total = Results.Values.Sum();
            @foreach (var option in Poll.Options)
            {
                var count = Results.GetValueOrDefault(option, 0);
                var pct = total > 0 ? (int)(100.0 * count / total) : 0;
                <div class="chart-row">
                    <span class="chart-label">@option</span>
                    <div class="chart-bar-track">
                        <div class="chart-bar-fill" style="width: @(pct)%"></div>
                    </div>
                    <span class="chart-value">@count (@pct%)</span>
                </div>
            }

            @if (Poll.AllowOther)
            {
                var otherCount = Results.GetValueOrDefault("Other", 0);
                var otherPct = total > 0 ? (int)(100.0 * otherCount / total) : 0;
                <div class="chart-row">
                    <span class="chart-label">Other</span>
                    <div class="chart-bar-track">
                        <div class="chart-bar-fill" style="width: @(otherPct)%"></div>
                    </div>
                    <span class="chart-value">@otherCount (@otherPct%)</span>
                </div>

                @if (OtherResponses is not null && OtherResponses.Count > 0)
                {
                    <div class="other-responses-list">
                        @foreach (var text in OtherResponses)
                        {
                            <span class="other-response-item">"@text"</span>
                        }
                    </div>
                }
            }

            <div class="chart-total">@total responses</div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public Poll Poll { get; set; } = default!;
    [Parameter] public Dictionary<string, int>? Results { get; set; }
    [Parameter] public List<string>? OtherResponses { get; set; }
}

<style>
    .results-chart {
        background: rgba(255, 255, 255, 0.03);
        border-radius: 1rem;
        padding: 2rem;
    }

    .results-chart h3 {
        margin: 0 0 1.5rem;
        font-size: 1.75rem;
        text-align: center;
    }

    .chart-bars {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .chart-row {
        display: grid;
        grid-template-columns: 200px 1fr 100px;
        align-items: center;
        gap: 1rem;
    }

    .chart-label {
        font-size: 1.1rem;
        text-align: right;
    }

    .chart-bar-track {
        height: 2.5rem;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 0.5rem;
        overflow: hidden;
    }

    .chart-bar-fill {
        height: 100%;
        background: linear-gradient(90deg, #e94560, #0f3460);
        border-radius: 0.5rem;
        transition: width 0.5s ease;
    }

    .chart-value {
        font-size: 1.1rem;
        font-weight: 600;
        color: #e94560;
    }

    .chart-total {
        text-align: center;
        margin-top: 0.5rem;
        opacity: 0.5;
        font-size: 0.9rem;
    }

    .other-responses-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        max-height: 120px;
        overflow-y: auto;
        padding: 0.5rem 0 0.5rem 200px;
    }

    .other-response-item {
        font-size: 0.85rem;
        font-style: italic;
        color: rgba(255, 255, 255, 0.6);
        background: rgba(255, 255, 255, 0.05);
        padding: 0.25rem 0.5rem;
        border-radius: 0.25rem;
    }
</style>
