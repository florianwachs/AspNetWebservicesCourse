    }

    .btn-inline {
        background: none;
        border: 1px solid currentColor;
        color: inherit;
        padding: 0.15rem 0.5rem;
        border-radius: 0.3rem;
        cursor: pointer;
        font-size: 0.75rem;
        margin-left: 0.4rem;
    }

    .btn-inline:hover {
        opacity: 0.8;
    }

    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.6; }
    }
</style>
