    private void HandleSlideKeydown(KeyboardEventArgs e)
    {
        if (e.Key is "ArrowRight" or " ")
        {
            AdvanceSlideAsync();
        }
        else if (e.Key is "ArrowLeft")
        {
            GoBackSlideAsync();
        }
        else if (e.Key is "p" or "P")
        {
            ToggleCustomPollForm();
        }
        else if (e.Key is "Escape")
        {
            if (showPollEditModal)
            {
                showPollEditModal = false;
            }
            else if (showCustomPollForm)
            {
                showCustomPollForm = false;
            }
            else if (answeringQuestionId is not null)
            {
                CancelAnswer();
            }
        }
    }

