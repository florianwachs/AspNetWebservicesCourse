    // Import actions
    private async Task ImportRepo()
    {
        importRepoError = null;
        importRepoSuccess = null;
        showRepoDedupWarning = false;

        if (string.IsNullOrWhiteSpace(importRepoUrl))
        {
            importRepoError = "Please enter a GitHub repository URL.";
            return;
        }

        var trimmedUrl = importRepoUrl.Trim();

        if (!trimmedUrl.Contains("github.com") || trimmedUrl.Split('/').Length < 5)
        {
            importRepoError = "Invalid GitHub URL. Use format: https://github.com/owner/repo";
            return;
        }

        if (importedRepoUrls.Contains(trimmedUrl))
        {
            showRepoDedupWarning = true;
            return;
        }

        await DoImportRepo(trimmedUrl);
    }

    private async Task ConfirmRepoReimport()
    {
        showRepoDedupWarning = false;
        await DoImportRepo(importRepoUrl.Trim());
    }

    private async Task DoImportRepo(string url)
    {
        isImportingRepo = true;
        importRepoStatus = "🔍 Connecting to GitHub...";
        importRepoSuccess = null;
        StateHasChanged();

        try
        {
            importRepoStatus = "🔍 Fetching repository & drafting session...";
            StateHasChanged();

            lastImportDraft = await ContentImportService.ImportAndDraftAsync(
                url, session?.Title,
                string.IsNullOrWhiteSpace(importRepoBranch) ? null : importRepoBranch.Trim(),
                string.IsNullOrWhiteSpace(importRepoSubdir) ? null : importRepoSubdir.Trim());

            importHistory.Add(new ImportHistoryEntry(
                url,
                lastImportDraft.ImportResult.RecordCount,
                lastImportDraft.Draft.Topics.Count));

            importedRepoUrls.Add(url);
            importRepoSuccess = $"Successfully imported {lastImportDraft.ImportResult.RecordCount} documents!";
            importRepoUrl = "";
            RefreshKnowledgeBaseCount();
        }
        catch (Exception ex)
        {
            if (!url.Contains("github.com") || url.Split('/').Length < 5)
                importRepoError = "Invalid GitHub URL. Use format: https://github.com/owner/repo";
            else
                importRepoError = $"Import failed: {ex.Message}";
        }
        finally
        {
            isImportingRepo = false;
            importRepoStatus = "";
            StateHasChanged();
        }
    }

    private void AddDraftedTopicsToSession()
    {
        if (lastImportDraft is null || sessionContext is null || session is null) return;

        foreach (var topicDraft in lastImportDraft.Draft.Topics)
        {
            var topic = new SessionTopic
            {
                Id = Guid.NewGuid().ToString("N")[..8],
                Title = topicDraft.Title,
                Description = topicDraft.Description,
                Order = session.Topics.Count,
                Status = TopicStatus.Upcoming,
                TalkingPoints = topicDraft.TalkingPoints.ToList(),
                SuggestedPolls = topicDraft.SuggestedPolls.Select(p => new SuggestedPoll
                {
                    Question = p.Question,
                    Options = p.Options.ToList()
                }).ToList()
            };
            session.Topics.Add(topic);
        }

        // Generate and load slides for newly added topics, remapping topic IDs
        if (lastImportDraft is not null && !string.IsNullOrWhiteSpace(lastImportDraft.SlideMarkdown))
        {
            var newSlides = SlideMarkdownParser.Parse(lastImportDraft.SlideMarkdown);
            for (int i = 0; i < lastImportDraft.Draft.Topics.Count && i < session.Topics.Count; i++)
            {
                var draftTopicId = $"topic-{i}";
                var actualTopicId = session.Topics[session.Topics.Count - lastImportDraft.Draft.Topics.Count + i].Id;
                foreach (var slide in newSlides.Where(s => s.TopicId == draftTopicId))
                {
                    slide.TopicId = actualTopicId;
                }
            }
            var allSlides = sessionContext.AllSlides.ToList();
            allSlides.AddRange(newSlides);
            sessionContext.LoadSlides(allSlides);
        }

        lastImportDraft = null;
        RefreshState();
        StateHasChanged();
    }
}

