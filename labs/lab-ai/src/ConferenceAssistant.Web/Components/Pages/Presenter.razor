        editPollOptions = new List<string>(sp.Options);
        editAllowOther = true;
        editPollSource = PollSource.Suggested;
        showPollEditModal = true;
        selectedSuggestedPollIndex = -1;
    }

    private void ToggleCustomPollForm()
