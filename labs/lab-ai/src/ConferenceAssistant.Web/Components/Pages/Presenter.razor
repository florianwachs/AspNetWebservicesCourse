    private void AddCustomOption() => customPollOptions.Add("");

    private void RemoveCustomOption(int index)
    {
        if (index >= 0 && index < customPollOptions.Count && customPollOptions.Count > 2)
            customPollOptions.RemoveAt(index);
    }

    private bool IsCustomPollValid =>
        !string.IsNullOrWhiteSpace(customPollQuestion)
        && customPollOptions.Count(o => !string.IsNullOrWhiteSpace(o)) >= 2;

    private void LaunchCustomPoll()
    {
        if (!IsCustomPollValid || sessionContext is null) return;
        var options = customPollOptions.Where(o => !string.IsNullOrWhiteSpace(o)).Select(o => o.Trim()).ToList();
        var poll = sessionContext.CreatePoll(activeTopic?.Id, customPollQuestion.Trim(), options, PollSource.Custom, allowOther: allowOtherOption);
        sessionContext.ActivatePoll(poll.Id);
        showCustomPollForm = false;
        RefreshState();
    }

