    // Poll actions

    private async Task AutoGeneratePoll()
    {
        if (sessionContext is null || activeTopic is null || isGeneratingPoll) return;
        isGeneratingPoll = true;
        StateHasChanged();

        try
        {
            // Capture existing draft poll IDs so we can find the newly created one
            var existingPollIds = sessionContext.GetPollsForTopic(activeTopic.Id)
                .Select(p => p.Id).ToHashSet();

            await PollGenerationWorkflow.ExecuteAsync(activeTopic.Id);

            // Find the newly created draft poll
            var newPoll = sessionContext.GetPollsForTopic(activeTopic.Id)
                .FirstOrDefault(p => p.Status == PollStatus.Draft && !existingPollIds.Contains(p.Id));

            if (newPoll is not null)
            {
                editPollQuestion = newPoll.Question;
                editPollOptions = new List<string>(newPoll.Options);
                editAllowOther = newPoll.AllowOther;
                editPollSource = PollSource.Generated;
                showPollEditModal = true;
            }
            else
            {
                // Fallback: if the workflow didn't create a poll via tool, use suggested poll
                var suggested = activeTopic.SuggestedPolls.FirstOrDefault();
                if (suggested is not null)
                {
                    editPollQuestion = suggested.Question;
                    editPollOptions = new List<string>(suggested.Options);
                    editAllowOther = true;
                    editPollSource = PollSource.Generated;
                    showPollEditModal = true;
                }
            }
        }
        finally
        {
            isGeneratingPoll = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void LaunchSelectedSuggestedPoll()
    {
        if (activeTopic is null || selectedSuggestedPollIndex < 0 || sessionContext is null) return;
