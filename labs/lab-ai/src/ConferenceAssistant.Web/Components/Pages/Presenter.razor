@page "/presenter/{SessionCode}"
@layout ConferenceAssistant.Web.Components.Layout.PresenterLayout
@using ConferenceAssistant.Core.Models
@using ConferenceAssistant.Core.Services
@using ConferenceAssistant.Ingestion.Services
@implements IDisposable
@inject ISessionManager SessionManager
@using ConferenceAssistant.Web.Services
@using ConferenceAssistant.Ingestion.Models
@inject ISemanticSearchService SemanticSearchService
@inject IInsightGenerationService InsightGenerationService
@inject IContentImportService ContentImportService
@inject ISessionPersistenceService PersistenceService
@inject ISlideGenerationService SlideGenerationService
@inject ConferenceAssistant.Agents.Workflows.PollGenerationWorkflow PollGenerationWorkflow
@inject IQuestionAnsweringService QuestionAnsweringService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Presenter Dashboard</PageTitle>

<div class="presenter-page">
    @if (!isHostAuthenticated)
    {
        <div class="pin-gate">
            @if (sessionContext is not null)
            {
                <h2>🔒 @sessionContext.Session.Title</h2>
                <p>Enter the host PIN to access the presenter dashboard.</p>
            }
            else
            {
                <h2>🔒 Session Not Found</h2>
                <p>No session with code "@SessionCode" exists.</p>
            }
            @if (sessionContext is not null)
            {
                <div class="pin-form">
                    <input type="password" maxlength="6" @bind="pinInput" @bind:event="oninput"
                           placeholder="Host PIN" class="pin-input" @onkeydown="HandlePinKeydown" />
                    <button class="btn btn-primary" @onclick="ValidatePin">Unlock</button>
                </div>
                @if (pinError is not null)
                {
                    <p class="pin-error">@pinError</p>
                }
            }
        </div>
    }
    else if (session is null)
    {
        <div class="no-session">
            <h2>No session loaded</h2>
            <p>Load a conference outline to get started.</p>
        </div>
    }
    else
    {
        <!-- Session Controls (top bar) -->
        <div class="session-bar">
            <div class="session-header">
                <h1>@session.Title</h1>
                <span class="status-badge @session.Status.ToString().ToLower()">@session.Status</span>
                <span class="record-count" title="Knowledge base records">📚 @knowledgeBaseCount records</span>
            </div>
            <div class="session-controls">
                @if (session.Status == SessionStatus.Setup)
                {
                    <button class="btn btn-primary" @onclick="StartSession">🚀 Go Live</button>
                }
                else if (session.Status == SessionStatus.Live)
                {
                    <button class="btn btn-danger" @onclick="EndSession">⏹ End Session</button>
                }
            </div>
        </div>


        <div class="dashboard-grid">
            <!-- Left Column: Topic Outline + Import -->
            <div class="left-column">
                <div class="topic-outline">
                    <h3>📋 Topics</h3>
                    @{ var currentTopicId = activeSlide?.TopicId; }
                    @foreach (var topic in session.Topics.OrderBy(t => t.Order))
                    {
                        var slideCount = sessionContext?.AllSlides.Count(s => s.TopicId == topic.Id) ?? 0;
                        <div class="topic-item @(topic.Id == currentTopicId ? "current" : "") @(topic.Status == TopicStatus.Completed ? "completed" : "")"
                             @onclick="() => JumpToTopic(topic.Id)">
                            <div class="topic-item-title">
                                @if (topic.Status == TopicStatus.Completed)
                                {
                                    <span class="topic-check">✓</span>
                                }
                                @topic.Title
                            </div>
                            @if (slideCount > 0)
                            {
                                <span class="topic-slide-count">@slideCount slides</span>
                            }
                        </div>
                    }
                </div>

                <div class="import-section">
                    <button class="import-toggle" @onclick="() => isImportExpanded = !isImportExpanded">
                        📥 Import @(isImportExpanded ? "▾" : "▸")
                    </button>
                    @if (isImportExpanded)
                    {
                        <div class="import-content">
                            <p class="import-description">Import from GitHub to enrich the knowledge base.</p>

                            @if (!string.IsNullOrWhiteSpace(importRepoStatus))
                            {
                                <div class="import-status">@importRepoStatus</div>
                            }

                            @if (importRepoSuccess is not null)
                            {
                                <div class="import-success">✅ @importRepoSuccess</div>
                            }

                            @if (showRepoDedupWarning)
                            {
                                <div class="import-dedup-warning">⚠️ Already imported. Import again?
                                    <button class="btn-inline" @onclick="ConfirmRepoReimport">Yes</button>
                                    <button class="btn-inline" @onclick="() => showRepoDedupWarning = false">Cancel</button>
                                </div>
                            }

                            <div class="import-form">
                                <input type="text" @bind="importRepoUrl" placeholder="https://github.com/owner/repo or .../tree/branch/subdir" class="import-url-input" />
                                <button class="btn btn-primary" @onclick="ImportRepo" disabled="@isImportingRepo">
                                    @if (isImportingRepo)
                                    {
                                        <span>⏳ Importing...</span>
                                    }
                                    else
                                    {
                                        <span>📥 Import</span>
                                    }
                                </button>
                            </div>

                            <div class="import-options-row">
                                <div class="import-option">
                                    <label>Branch <span class="hint">(auto-detect)</span></label>
                                    <input type="text" @bind="importRepoBranch" placeholder="e.g., main" class="import-option-input" />
                                </div>
                                <div class="import-option">
                                    <label>Subdirectory <span class="hint">(optional)</span></label>
                                    <input type="text" @bind="importRepoSubdir" placeholder="e.g., scenarios" class="import-option-input" />
                                </div>
                            </div>

                            @if (importRepoError is not null)
                            {
                                <div class="import-error">@importRepoError</div>
                            }

                            @if (importHistory.Count > 0)
                            {
                                <div class="import-history">
                                    <h4>Import History</h4>
                                    @foreach (var entry in importHistory)
                                    {
                                        <div class="import-entry">
                                            <span class="import-url">@entry.Url</span>
                                            <span class="import-count">📄 @entry.DocumentCount docs</span>
                                            <span class="import-topics">🎯 @entry.TopicCount topics</span>
                                        </div>
                                    }
                                </div>
                            }

                            @if (lastImportDraft is not null && lastImportDraft.Draft.Topics.Count > 0)
                            {
                                <div class="import-draft-actions">
                                    <h4>Add Drafted Topics to Session?</h4>
                                    <p class="muted">The AI drafted @lastImportDraft.Draft.Topics.Count topic(s) from the imported content.</p>
                                    @foreach (var topic in lastImportDraft.Draft.Topics)
                                    {
                                        <div class="draft-topic-item">
                                            <span>@topic.Title</span>
                                            <span class="tp-count">@topic.TalkingPoints.Count points, @topic.SuggestedPolls.Count polls</span>
                                        </div>
                                    }
                                    <button class="btn btn-primary" @onclick="AddDraftedTopicsToSession">➕ Add All Topics</button>
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- Settings Section -->
                <div class="settings-section">
                    <button class="section-toggle" @onclick="() => isSettingsExpanded = !isSettingsExpanded">
                        ⚙️ Settings @(isSettingsExpanded ? "▾" : "▸")
                    </button>
                    @if (isSettingsExpanded)
                    {
                        <div class="settings-content">
                            @if (confirmClear is null)
                            {
                                <button class="btn btn-sm btn-danger-outline" @onclick='() => confirmClear = "polls"'>🗑️ Clear Polls</button>
                                <button class="btn btn-sm btn-danger-outline" @onclick='() => confirmClear = "qa"'>🗑️ Clear Q&amp;A</button>
                                <button class="btn btn-sm btn-danger-outline" @onclick='() => confirmClear = "all"'>🗑️ Clear All Data</button>
                                <hr style="margin: 0.5rem 0; border-color: rgba(255,255,255,0.1);" />
                                <button class="btn btn-sm btn-danger-outline" @onclick='() => confirmClear = "session"'>⚠️ Delete Session</button>
                            }
                            else
                            {
                                <div class="clear-confirm">
                                    @if (confirmClear == "session")
                                    {
                                        <p>⚠️ Permanently delete this session and all its data? This cannot be undone.</p>
                                    }
                                    else
                                    {
                                        <p>Clear @confirmClear data? This cannot be undone.</p>
                                    }
                                    <button class="btn btn-sm btn-danger" @onclick="ExecuteClear">Confirm</button>
                                    <button class="btn btn-sm" @onclick='() => confirmClear = null'>Cancel</button>
                                </div>
                            }
                            @if (clearMessage is not null)
                            {
                                <p class="clear-message">@clearMessage</p>
                            }
                        </div>
                    }
                </div>
            </div>
            <div class="panel center-column" tabindex="0" @onkeydown="HandleSlideKeydown">
                @if (activeSlide is not null)
                {
                    <div class="center-slide-area">
                        <SlideRenderer Slide="@activeSlide" Compact="true" />
                    </div>

                    @if (nextSlide is not null)
                    {
                        <div class="up-next-preview">
                            <span class="up-next-label">Up Next</span>
                            <SlideRenderer Slide="@nextSlide" Compact="true" />
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(activeSlide.SpeakerNotes))
                    {
                        <div class="center-notes">
                            <span>🎤</span> @activeSlide.SpeakerNotes
                        </div>
                    }

                    <div class="center-nav">
                        <button class="btn btn-sm" @onclick="GoBackSlideAsync" disabled="@((sessionContext?.ActiveSlideIndex ?? -1) <= 0)">◀ Prev</button>
                        <span class="slide-progress">Slide @((sessionContext?.ActiveSlideIndex ?? -1) + 1) / @(sessionContext?.TotalSlides ?? 0)</span>
                        <button class="btn btn-sm" @onclick="AdvanceSlideAsync" disabled="@((sessionContext?.ActiveSlideIndex ?? -1) >= (sessionContext?.TotalSlides ?? 0) - 1)">Next ▶</button>
                        <button class="btn btn-sm @(slidesHidden ? "btn-warning" : "")" @onclick="ToggleSlidesVisibility" title="@(slidesHidden ? "Show slides on display" : "Hide slides from display")">
                            @(slidesHidden ? "👁️‍🗨️ Hidden" : "👁️ Visible")
                        </button>
                    </div>
                }
                else
                {
                    <div class="no-active-slide">
                        <span class="empty-icon">🎬</span>
                        <p>Activate a topic or advance to a slide to start presenting.</p>
                    </div>
                }

                <div class="keyboard-hints">
                    <span>← → Navigate</span> <span>P Poll</span> <span>Esc Close</span>
                </div>

                <!-- Quick Poll Launch -->
                @if (activePoll is null || activePoll.Status == PollStatus.Closed)
                {
                    <div class="poll-launch-zone">
                        @if (activeTopic is not null)
                        {
                            <button class="btn btn-outline btn-sm" @onclick="AutoGeneratePoll" disabled="@isGeneratingPoll">
                                @if (isGeneratingPoll)
                                {
                                    <span>⏳ Generating...</span>
                                }
                                else
                                {
                                    <span>🤖 Auto-Generate Poll</span>
                                }
                            </button>
                        }

                        @if (activeTopic?.SuggestedPolls.Count > 0)
                        {
                            <div class="suggested-poll-picker">
                                <select @bind="selectedSuggestedPollIndex">
                                    <option value="-1">— Use Suggested Poll —</option>
                                    @for (var i = 0; i < activeTopic.SuggestedPolls.Count; i++)
                                    {
                                        <option value="@i">@activeTopic.SuggestedPolls[i].Question</option>
                                    }
                                </select>
                                <button class="btn btn-sm btn-primary"
                                        disabled="@(selectedSuggestedPollIndex < 0)"
                                        @onclick="LaunchSelectedSuggestedPoll">
                                    Launch
                                </button>
                            </div>
                        }

                        <button class="btn btn-outline btn-sm" @onclick="ToggleCustomPollForm">✏️ Custom Poll</button>
                        @if (showCustomPollForm)
                        {
                            <div class="custom-poll-inputs">
                                <input type="text" @bind="customPollQuestion" placeholder="Poll question..." />
                                @for (var i = 0; i < customPollOptions.Count; i++)
                                {
                                    var index = i;
                                    <div class="option-row">
                                        <input type="text"
                                               value="@customPollOptions[index]"
                                               @onchange="(e) => UpdateCustomOption(index, e.Value?.ToString() ?? string.Empty)"
                                               placeholder="Option @(index + 1)..." />
                                        @if (customPollOptions.Count > 2)
                                        {
                                            <button class="btn-icon" @onclick="() => RemoveCustomOption(index)">✕</button>
                                        }
                                    </div>
                                }
                                <div class="custom-poll-actions">
                                    <button class="btn btn-sm" @onclick="AddCustomOption">+ Add Option</button>
                                    <label class="allow-other-label">
                                        <input type="checkbox" @bind="allowOtherOption" /> ☑ Allow 'Other' responses
                                    </label>
                                    <button class="btn btn-sm btn-primary"
                                            disabled="@(!IsCustomPollValid)"
                                            @onclick="LaunchCustomPoll">
                                        🚀 Create &amp; Go Live
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Right Column: Q&A + Active Poll + Insights -->
            <div class="right-column">
                <div class="qa-feed">
                    <h3>❓ Q&amp;A <span class="qa-count">(@allQuestions.Count)</span></h3>
                    @if (allQuestions.Count == 0)
                    {
                        <div class="empty-state">
                            <span class="empty-icon">💬</span>
                            <p class="muted">No questions yet. Attendees can ask questions from their devices.</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var q in allQuestions)
                        {
                            <div class="question-item @(!q.IsSafe && !q.IsApprovedByPresenter ? "question-unsafe" : "") @(!q.IsSafe && q.IsApprovedByPresenter ? "question-approved" : "")">
                                <div class="question-header">
                                    <span class="upvote-count">👍 @q.Upvotes</span>
                                    @if (!q.IsSafe && !q.IsApprovedByPresenter)
                                    {
                                        <span class="unsafe-badge">⚠️ Unsafe</span>
                                    }
                                    else if (!q.IsSafe && q.IsApprovedByPresenter)
                                    {
                                        <span class="approved-badge">✅ Approved</span>
                                    }
                                    <span class="question-text">@q.Text</span>
                                    @if (!q.IsSafe && !q.IsApprovedByPresenter)
                                    {
                                        <button class="btn-icon approve-btn" @onclick="() => ApproveQuestion(q.Id)" title="Approve and show to attendees">
                                            ✅
                                        </button>
                                    }
                                    <button class="btn-icon spotlight-btn @(sessionContext?.SpotlightedQuestion?.Id == q.Id ? "spotlight-active" : "")"
                                            @onclick="() => ToggleSpotlight(q.Id)"
                                            title="@(sessionContext?.SpotlightedQuestion?.Id == q.Id ? "Remove from display" : "Show on display")">
                                        📺
                                    </button>
                                    <button class="btn-icon delete-btn" @onclick="() => DeleteQuestion(q.Id)" title="Remove question">🗑️</button>
                                    @if (!string.IsNullOrEmpty(q.TopicId))
                                    {
                                        var qTopic = session?.Topics.FirstOrDefault(t => t.Id == q.TopicId);
                                        @if (qTopic is not null)
                                        {
                                            <span class="question-topic-badge">@qTopic.Title</span>
                                        }
                                    }
                                </div>
                                @if (q.Answers.Count > 0)
                                {
                                    @foreach (var answer in q.Answers)
                                    {
                                        <div class="question-answer @(answer.IsAiGenerated ? "ai-answer" : "")">
                                            @if (answer.IsAiGenerated)
                                            {
                                                <span class="ai-badge">🤖 AI</span>
                                            }
                                            else
                                            {
                                                <span class="human-badge">💬 @answer.AuthorLabel</span>
                                            }
                                            <strong>A:</strong> @answer.Text
                                        </div>
                                    }
                                }
                                @if (answeringQuestionId == q.Id)
                                {
                                    <div class="answer-form">
                                        <input type="text" @bind="answerText" placeholder="Type your answer..." />
                                        <button class="btn btn-sm btn-primary" @onclick="() => SubmitAnswer(q.Id)">Submit</button>
                                        <button class="btn btn-sm" @onclick="CancelAnswer">Cancel</button>
                                    </div>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-answer" @onclick="() => StartAnswering(q.Id)">💬 Add Answer</button>
                                }
                            </div>
                        }
                    }
                </div>

                @if (activePoll is not null && activePoll.Status != PollStatus.Closed)
                {
                    <div class="right-poll-section @(activePoll.Status == PollStatus.Active ? "poll-active-glow" : "")">
                        <h3>📊 Live Poll</h3>
                        <h4>@activePoll.Question</h4>
                        <div class="poll-options-display">
                            @foreach (var option in activePoll.Options)
                            {
                                var count = activePollResults?.GetValueOrDefault(option, 0) ?? 0;
                                var total = activePollResults?.Values.Sum() ?? 0;
                                var pct = total > 0 ? (int)(100.0 * count / total) : 0;
                                <div class="poll-option-bar">
                                    <div class="poll-option-fill" style="width: @(pct)%"></div>
                                    <span class="poll-option-label">@option</span>
                                    <span class="poll-option-count">@count (@(pct)%)</span>
                                </div>
                            }
                            @if (activePoll.AllowOther)
                            {
                                var otherCount = activePollResults?.GetValueOrDefault("Other", 0) ?? 0;
                                var total = activePollResults?.Values.Sum() ?? 0;
                                var otherPct = total > 0 ? (int)(100.0 * otherCount / total) : 0;
                                <div class="poll-option-bar">
                                    <div class="poll-option-fill" style="width: @(otherPct)%"></div>
                                    <span class="poll-option-label">Other</span>
                                    <span class="poll-option-count">@otherCount (@(otherPct)%)</span>
                                </div>
                                var otherTexts = sessionContext?.GetOtherResponses(activePoll.Id);
                                @if (otherTexts is not null && otherTexts.Count > 0)
                                {
                                    <div class="other-texts-inline">
                                        @foreach (var t in otherTexts)
                                        {
                                            <span class="other-text-chip">"@t"</span>
                                        }
                                    </div>
                                }
                            }
                        </div>
                        @if (activePoll.Status == PollStatus.Draft)
                        {
                            <button class="btn btn-primary btn-sm" @onclick="() => ActivatePollAsync(activePoll.Id)">📡 Go Live</button>
                        }
                        else if (activePoll.Status == PollStatus.Active)
                        {
                            <button class="btn btn-danger btn-sm" @onclick="() => ClosePollAsync(activePoll.Id)">🔒 Close Poll</button>
                        }
                    </div>
                }

                @if (closedPoll is not null)
                {
                    <div class="closed-poll-results">
                        <h4>Last Poll Results: @closedPoll.Question</h4>
                        <PollResultsChart Poll="@closedPoll" Results="@closedPollResults"
                                          OtherResponses="@(closedPoll.AllowOther ? sessionContext?.GetOtherResponses(closedPoll.Id) : null)" />
                    </div>
                }

                <div class="insights-section">
                    <h3>💡 Insights</h3>
                    @if (topicInsights.Count == 0)
                    {
                        <div class="empty-state">
                            <span class="empty-icon">🔍</span>
                            <p class="muted">No insights yet for this topic.</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var insight in topicInsights)
                        {
                            <InsightCard Insight="@insight" />
                        }
                    }
                </div>
            </div>
        </div>
    }
</div>

@if (showPollEditModal)
{
    <div class="poll-edit-overlay" @onclick="CancelPollEdit">
        <div class="poll-edit-modal" @onclick:stopPropagation="true">
            <h3>📊 Edit Poll Before Launch</h3>
            <div class="poll-edit-field">
                <label>Question</label>
                <input type="text" @bind="editPollQuestion" placeholder="Poll question..." />
            </div>
            <div class="poll-edit-field">
                <label>Options</label>
                @for (var i = 0; i < editPollOptions.Count; i++)
                {
                    var index = i;
                    <div class="poll-edit-option-row">
                        <input type="text"
                               value="@editPollOptions[index]"
                               @onchange="(e) => UpdateEditPollOption(index, e.Value?.ToString() ?? string.Empty)"
                               placeholder="Option @(index + 1)..." />
                        @if (editPollOptions.Count > 2)
                        {
                            <button class="btn-icon" @onclick="() => RemoveEditPollOption(index)">✕</button>
                        }
                    </div>
                }
                <button class="btn btn-sm" @onclick="AddEditPollOption">+ Add Option</button>
            </div>
            <div class="poll-edit-field">
                <label class="allow-other-label">
                    <input type="checkbox" @bind="editAllowOther" /> Allow 'Other' responses
                </label>
            </div>
            <div class="poll-edit-actions">
                <button class="btn btn-sm" @onclick="CancelPollEdit">Cancel</button>
                <button class="btn btn-sm btn-primary" disabled="@(!IsEditPollValid)" @onclick="LaunchEditedPoll">🚀 Launch Poll</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string SessionCode { get; set; } = "";

    // PIN gate state
    private bool isHostAuthenticated = false;
    private string pinInput = "";
    private string? pinError;
    private SessionContext? sessionContext;

    private ConferenceSession? session;
    private SessionTopic? activeTopic;
    private Poll? activePoll;
    private Dictionary<string, int>? activePollResults;
    private Poll? closedPoll;
    private Dictionary<string, int>? closedPollResults;
    private IReadOnlyList<Insight> topicInsights = [];
    private IReadOnlyList<AudienceQuestion> topicQuestions = [];
    private IReadOnlyList<AudienceQuestion> allQuestions = [];
    private int knowledgeBaseCount;

    // Suggested poll selection
    private int selectedSuggestedPollIndex = -1;

    // Custom poll form
    private bool showCustomPollForm;
    private string customPollQuestion = "";
    private List<string> customPollOptions = ["", ""];
    private bool allowOtherOption = true;
    private bool isGeneratingPoll;

    // Question answering
    private string? answeringQuestionId;
    private string answerText = "";

    // Import section collapse state
    private bool isImportExpanded;

    // Settings / clear data state
    private bool isSettingsExpanded;
    private string? confirmClear;
    private string? clearMessage;

    // Import tab state
    private string importRepoUrl = "";
    private string importRepoBranch = "";
    private string importRepoSubdir = "";
    private bool isImportingRepo;
    private string? importRepoError;
    private string importRepoStatus = "";
    private string? importRepoSuccess;
    private ImportDraftResult? lastImportDraft;
    private List<ImportHistoryEntry> importHistory = [];
    private HashSet<string> importedRepoUrls = [];
    private bool showRepoDedupWarning;

    private record ImportHistoryEntry(string Url, int DocumentCount, int TopicCount);

    // Slide navigation
    private Slide? activeSlide;
    private Slide? nextSlide;
    private Action<Slide>? onSlideChanged;

    // Slides visibility
    private bool slidesHidden;

    // Poll edit modal
    private bool showPollEditModal;
    private string editPollQuestion = "";
    private List<string> editPollOptions = ["", ""];
    private bool editAllowOther = true;
    private PollSource editPollSource = PollSource.Custom;

    // Event handler references for cleanup
    private Action<PollResponse>? onResponseReceived;
    private Action<Poll>? onPollActivated;
    private Action<Poll>? onPollClosed;
    private Action<AudienceQuestion>? onQuestionReceived;
    private Action<AudienceQuestion>? onQuestionAnswered;
    private Action<AudienceQuestion>? onQuestionUpvoted;
    private Action<Insight>? onInsightGenerated;
    private Action<bool>? onSlidesVisibilityChanged;
    private Action<AudienceQuestion?>? onQuestionSpotlighted;
    private Action<AudienceQuestion>? onQuestionRemoved;
    private Action<AudienceQuestion>? onQuestionModerated;
    private Timer? _knowledgeBaseTimer;

    protected override void OnInitialized()
    {
        sessionContext = SessionManager.GetSession(SessionCode);
    }

    private void ValidatePin()
    {
        if (SessionManager.ValidateHostPin(SessionCode, pinInput))
        {
            isHostAuthenticated = true;
            pinError = null;
            sessionContext = SessionManager.GetSession(SessionCode);
            InitializeSession();
        }
        else
        {
            pinError = "Invalid PIN. Please try again.";
        }
    }

    private void HandlePinKeydown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") ValidatePin();
    }

    private async void InitializeSession()
    {
        if (sessionContext is null) return;
        session = sessionContext.Session;
        RefreshState();

        try { knowledgeBaseCount = await SemanticSearchService.GetRecordCountAsync(); }
        catch { knowledgeBaseCount = 0; }

        onResponseReceived = _ => InvokeAsync(() => { RefreshPollResults(); StateHasChanged(); });
        onPollActivated = _ => InvokeAsync(() => { RefreshState(); StateHasChanged(); });
        onPollClosed = _ => InvokeAsync(() => { RefreshState(); RefreshKnowledgeBaseCount(); StateHasChanged(); });
        onQuestionReceived = _ => InvokeAsync(() => { RefreshQuestions(); RefreshKnowledgeBaseCount(); StateHasChanged(); });
        onQuestionAnswered = _ => InvokeAsync(() => { RefreshQuestions(); RefreshKnowledgeBaseCount(); StateHasChanged(); });
        onQuestionUpvoted = _ => InvokeAsync(() => { RefreshQuestions(); StateHasChanged(); });
        onInsightGenerated = _ => InvokeAsync(() => { RefreshInsights(); RefreshKnowledgeBaseCount(); StateHasChanged(); });
        onSlideChanged = _ => InvokeAsync(() => { activeSlide = sessionContext?.ActiveSlide; nextSlide = sessionContext?.GetNextSlide(); StateHasChanged(); });

        sessionContext.ResponseReceived += onResponseReceived;
        sessionContext.PollActivated += onPollActivated;
        sessionContext.PollClosed += onPollClosed;
        sessionContext.QuestionReceived += onQuestionReceived;
        sessionContext.QuestionAnswered += onQuestionAnswered;
        sessionContext.QuestionUpvoted += onQuestionUpvoted;
        sessionContext.InsightGenerated += onInsightGenerated;
        sessionContext.SlideChanged += onSlideChanged;

        onSlidesVisibilityChanged = visible => InvokeAsync(() => { slidesHidden = !visible; StateHasChanged(); });
        sessionContext.SlidesVisibilityChanged += onSlidesVisibilityChanged;

        onQuestionSpotlighted = _ => InvokeAsync(StateHasChanged);
        sessionContext.QuestionSpotlighted += onQuestionSpotlighted;

        onQuestionRemoved = _ => InvokeAsync(() => { RefreshQuestions(); StateHasChanged(); });
        sessionContext.QuestionRemoved += onQuestionRemoved;

        onQuestionModerated = _ => InvokeAsync(() => { RefreshQuestions(); StateHasChanged(); });
        sessionContext.QuestionModerated += onQuestionModerated;

        slidesHidden = sessionContext.SlidesHidden;

        // Periodic refresh of knowledge base count (catches background ingestion)
        _knowledgeBaseTimer = new Timer(_ =>
            InvokeAsync(() => { RefreshKnowledgeBaseCount(); StateHasChanged(); }),
            null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));

        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _knowledgeBaseTimer?.Dispose();
        if (sessionContext is not null)
        {
            sessionContext.ResponseReceived -= onResponseReceived;
            sessionContext.PollActivated -= onPollActivated;
            sessionContext.PollClosed -= onPollClosed;
            sessionContext.QuestionReceived -= onQuestionReceived;
            sessionContext.QuestionAnswered -= onQuestionAnswered;
            sessionContext.QuestionUpvoted -= onQuestionUpvoted;
            sessionContext.InsightGenerated -= onInsightGenerated;
            sessionContext.SlideChanged -= onSlideChanged;
            sessionContext.SlidesVisibilityChanged -= onSlidesVisibilityChanged;
            sessionContext.QuestionSpotlighted -= onQuestionSpotlighted;
            sessionContext.QuestionRemoved -= onQuestionRemoved;
            sessionContext.QuestionModerated -= onQuestionModerated;
        }
    }

    private async Task ExecuteClear()
    {
        if (sessionContext is null || session is null) return;

        try
        {
            if (confirmClear == "session")
            {
                await PersistenceService.DeleteSessionAsync(session.Id);
                SessionManager.RemoveSession(session.SessionCode);
                confirmClear = null;
                Navigation.NavigateTo("/", forceLoad: true);
                return;
            }

            await PersistenceService.ClearRuntimeDataAsync(session.Id);
            sessionContext.ClearRuntimeData();
            RefreshState();

            clearMessage = confirmClear switch
            {
                "polls" => "✅ Polls & responses cleared.",
                "qa" => "✅ Q&A data cleared.",
                "all" => "✅ All runtime data cleared.",
                _ => "✅ Data cleared."
            };
        }
        catch (Exception ex)
        {
            clearMessage = $"❌ Error: {ex.Message}";
        }

        confirmClear = null;
        StateHasChanged();
    }

    private void RefreshState()
    {
        if (sessionContext is null) return;
        session = sessionContext.Session;
        activeTopic = sessionContext.GetActiveTopic();
        activeSlide = sessionContext.ActiveSlide;
        nextSlide = sessionContext.GetNextSlide();

        var previousPoll = activePoll;
        activePoll = sessionContext.GetActivePoll();
        RefreshPollResults();

        // Track the last closed poll for displaying final results
        if (previousPoll is not null && previousPoll.Status != PollStatus.Closed && activePoll is null)
        {
            closedPoll = previousPoll;
            closedPollResults = sessionContext.GetPollResults(previousPoll.Id);
        }

        allQuestions = sessionContext.GetTopQuestions(50, includeUnsafe: true);

        if (activeTopic is not null)
        {
            topicInsights = sessionContext.GetInsightsForTopic(activeTopic.Id);
            topicQuestions = sessionContext.GetQuestionsForTopic(activeTopic.Id);

            // Track most recently closed poll for this topic
            var topicPolls = sessionContext.GetPollsForTopic(activeTopic.Id);
            var lastClosed = topicPolls.LastOrDefault(p => p.Status == PollStatus.Closed);
            if (lastClosed is not null && activePoll is null)
            {
                closedPoll = lastClosed;
                closedPollResults = sessionContext.GetPollResults(lastClosed.Id);
            }
        }
        else
        {
            topicInsights = [];
            topicQuestions = [];
        }

        ResetPollForm();
    }

    private void RefreshPollResults()
    {
        if (activePoll is not null)
            activePollResults = sessionContext?.GetPollResults(activePoll.Id);
    }

    private void RefreshQuestions()
    {
        allQuestions = sessionContext?.GetTopQuestions(50, includeUnsafe: true) ?? [];
        if (activeTopic is not null)
            topicQuestions = sessionContext?.GetQuestionsForTopic(activeTopic.Id) ?? [];
        else
            topicQuestions = [];
    }

